/* Style global de l'application */
QMainWindow {
    background-color: #1e1e2e;
}

QWidget {
    font-family: "Segoe UI", sans-serif;
    font-size: 13px;
    color: #cdd6f4;
}

QPushButton {
    background-color: #89b4fa;
    color: #1e1e2e;
    border: none;
    border-radius: 6px;
    padding: 6px 14px;
}

QPushButton:hover {
    background-color: #b4befe;
}

QLineEdit {
    background-color: #313244;
    border: 1px solid #45475a;
    border-radius: 4px;
    padding: 4px 8px;
}
